<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Local packages with fixed Semver 3.x compatibility -->
    <add key="local-packages" value="local-packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <packageSourceMapping>
    <!-- Use local packages for Pulumi SDK with Semver fix -->
    <packageSource key="local-packages">
      <package pattern="Pulumi" />
      <package pattern="Pulumi.Automation" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
